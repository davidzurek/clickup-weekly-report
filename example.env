# Environment variables for ClickUp weekly report
LOCATION="your-region"
PROJECT_ID="your-project-id"
REPOSITORY="clickup"
IMAGE_NAME="clickup-weekly-report"
JOB_NAME="your-job-name"

WORKSPACE_ID="your-workspace-id" # e.g. "2634247"
FOLDER_ID="your-folder-id" # e.g. "90121162200"
USER_ID="your-user-id" # e.g. "12345678"
DOC_ID="your-doc-id" # e.g. "1abc2-123456"
PARENT_PAGE_ID="your-parent-page-id" # e.g. "1abc2-456789"
LOOKBACK_DAYS="your-lookback-days" # e.g. "7"
PAGE_PREFIX="your-page-prefix" # e.g. "CW"
